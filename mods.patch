+                        tab[tabParameter] = int(raw_value);
+                    }
+                }
+
+                // trace(hairMod + " " + beltMod + " " + ribbonMod + " " + markMod);
+
+                if (hairMod != null) {
+                    setter.flagModifiedHairEx(hairMod);
+                }
+
+                if (beltMod != null) {
+                    setter.flagModifiedBelt(beltMod);
