+          * since we don't have a contiguous list of child indices.
+          */
+         try {
+            for (var j = sprites.length-1; j > 0; j--) {
+               for (var i = 0; i < j; i++) {
+                  var idxA = parent.getChildIndex(sprites[i]);
+                  var idxB = parent.getChildIndex(sprites[i+1]);
+                  if (idxB < idxA) {
+                     parent.swapChildren(sprites[i], sprites[i+1]);
+                     swaps += 1;
+                  }
+               }
+            }
+         }
+         catch(myError:Error)
+         {
+            trace(myError.getStackTrace());
+         }
