+                            catch(myError:Error) {}
+                        } else {
+                            var buf:ByteArray = new ByteArray();
+                            buf.writeObject(MenuClass.charaDefoData[character][tabName][tabParameter]);
+                            buf.position = 0;
+                            tab[tabParameter] = buf.readObject();
